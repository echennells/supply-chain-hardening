; Managed by ansible-supply-chain-security
minimum-release-age={{ pnpm_minimum_release_age_minutes }}
minimum-release-age-strict={{ pnpm_minimum_release_age_strict | bool | lower }}
{% for pkg in pnpm_minimum_release_age_exclude %}
minimum-release-age-exclude[]={{ pkg }}
{% endfor %}
; block-exotic-subdeps refuses git / http(s) / tarball-URL dependencies.
; Runtime enforcement requires pnpm 11+. On pnpm 10 the key is accepted
; into config but silently ignored — DNS/install proceeds for exotic
; deps. Tier-tested via the matrix; the version gap is documented in
; tests/matrix/expected-skips.yml so the behavioral test isn't flagged
; as a regression on pnpm 10 cells.
block-exotic-subdeps=true
{% if pnpm_built_dependencies | length > 0 %}
; Explicit build-script allowlist (pnpm 11+). Listed packages may run build
; scripts; everything else is blocked. Override /etc/npmrc's
; ignore-scripts=true explicitly — pnpm merges config per-key, and an
; omitted key here would let the system-wide value win (silently disabling
; this allowlist). The allowlist below is what actually constrains scripts.
ignore-scripts=false
{% for pkg in pnpm_built_dependencies %}
only-built-dependencies[]={{ pkg }}
{% endfor %}
{% else %}
; No build scripts allowed for any package — equivalent default-deny via the
; older mechanism (works on pnpm 8-11+). To allow specific packages to run
; build scripts, set pnpm_built_dependencies in role vars.
ignore-scripts=true
{% endif %}
