#!/bin/sh
# Managed by ansible-supply-chain-security
# System-wide supply chain hardening — loaded by /etc/profile.d/

# === npm / pnpm / yarn / bun ===
export NPM_CONFIG_IGNORE_SCRIPTS={{ npm_ignore_scripts | lower }}
export NPM_CONFIG_AUDIT={{ npm_audit | lower }}
export NPM_CONFIG_SAVE_EXACT={{ npm_save_exact | lower }}
export NPM_CONFIG_FUND={{ npm_fund | lower }}
export NPM_CONFIG_UPDATE_NOTIFIER={{ npm_update_notifier | lower }}
export NPM_CONFIG_MINIMUM_RELEASE_AGE={{ npm_minimum_release_age_days }}

# === Python (pip / uv) ===
export PYTHONDONTWRITEBYTECODE={{ python_dont_write_bytecode | int }}
export PIP_DISABLE_PIP_VERSION_CHECK={{ pip_disable_version_check | int }}
export UV_LINK_MODE=copy

# === Go ===
# Sumdb + proxy stay active. GOPRIVATE / GONOPROXY / GOINSECURE are emptied so
# no module is exempted from sumdb checks, proxy traffic, or HTTPS. GOTOOLCHAIN
# locks to the installed toolchain to prevent auto-download of alternatives.
export GOSUMDB='{{ go_sumdb }}'
export GOPROXY='{{ go_proxy }}'
export GOFLAGS='-mod={{ goflags_mod }}'
export GOPRIVATE='{{ go_private }}'
export GONOPROXY='{{ go_noproxy }}'
export GOINSECURE='{{ go_insecure }}'
export GOTOOLCHAIN=local

# === PHP (Composer) ===
# Belt-and-suspenders for `php composer.phar` callers that bypass our
# /usr/local/bin/composer wrapper but inherit the system env. Composer
# 2.9+ honors COMPOSER_SKIP_SCRIPTS=<event,list> by skipping dispatch
# of any user-defined script registered for the named events. Below is
# the full enumeration from composer's ScriptEvents + PackageEvents +
# PluginEvents at the time of writing. Composer silently ignores unknown
# names, so extra events here are harmless if composer drops one in the
# future — but a NEW event added by composer that we don't list here
# slips through. The /usr/local/bin/composer wrapper is the primary
# protection; this env var is the backup for shells that bypass it.
export COMPOSER_SKIP_SCRIPTS='pre-install-cmd,post-install-cmd,pre-update-cmd,post-update-cmd,pre-status-cmd,post-status-cmd,pre-autoload-dump,post-autoload-dump,post-root-package-install,post-create-project-cmd,pre-archive-cmd,post-archive-cmd,pre-package-install,post-package-install,pre-package-update,post-package-update,pre-package-uninstall,post-package-uninstall,init,command,pre-file-download,post-file-download,pre-command-run,pre-pool-create'
export COMPOSER_ALLOW_SUPERUSER=1
