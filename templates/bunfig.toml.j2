{%- set v = bun_detected_version | default('', true) -%}
{%- set has_text_lockfile = v == '' or v is version('1.2.0', '>=') -%}
# Managed by ansible-supply-chain-security
#
# frozenLockfile refuses install if package.json diverges from the
# lockfile — catches sneaky dep additions during build. Universal
# across all bun versions.
#
# auto = "disable" prevents bun's runtime auto-install feature from
# silently grabbing missing deps when you `bun run` something — a real
# foot-gun in CI/agent contexts where deps should be deterministic.
#
# saveTextLockfile uses text-format bun.lock (diff-able for audit)
# instead of the binary bun.lockb. Added in bun 1.2; older bun ignores
# the key but defaults to binary format.
[install]
minimumReleaseAge = {{ bun_minimum_release_age_seconds }}
exact = {{ bun_exact | bool | lower }}
lifecycleScripts = {{ bun_lifecycle_scripts | bool | lower }}
frozenLockfile = {{ bun_frozen_lockfile | bool | lower }}
auto = "{{ bun_auto }}"
{% if has_text_lockfile and bun_save_text_lockfile %}
saveTextLockfile = true
{% endif %}
{% if bun_security_scanner | length > 0 %}

# Hook bun install into a third-party security scanner that implements
# Bun.Security.Scanner ({ version: '1', scan: async ({packages}) => Advisory[] }).
# Socket publishes @socketsecurity/bun-security-scanner on npm — install
# per-project with `bun add -d <name>` so bun's resolver finds it. If the
# scanner package isn't installed in the project being installed against,
# bun install will fail loudly — that's why this section is opt-in via
# the bun_security_scanner role variable (empty by default).
[install.security]
scanner = "{{ bun_security_scanner }}"
{% endif %}
