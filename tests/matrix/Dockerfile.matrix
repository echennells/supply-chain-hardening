# Cross-distro matrix container.
# Parameterized by BASE_IMAGE so the same Dockerfile builds for Ubuntu
# 22.04, Ubuntu 24.04, Debian 12, etc. run-docker.sh wraps this and
# iterates the distros declared in its DISTROS list.
#
# Layer ordering is deliberate for build-cache reuse:
#   1. base image (rarely changes)
#   2. apt install ansible/git/etc. (changes only on bootstrap-deps changes)
#   3. install-versions.yml COPY + RUN (the slow step — caches unless the
#      playbook content itself changes; rest of the repo can churn freely)
#   4. COPY the rest of the role (invalidated per commit but cheap)
#
# This means a typical "change one bats test, re-run cross-distro" only
# pays the COPY cost, not the apt + PHP-install cost.

ARG BASE_IMAGE=ubuntu:24.04
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# Bootstrap prereqs only — everything else installs via the playbook.
# ansible-core covers Debian 12 + Ubuntu 22.04/24.04 with the same package
# name. ca-certificates needed for the getcomposer.org HTTPS fetches in
# install-versions.yml.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ansible-core \
        git \
        ca-certificates \
        sudo \
        curl \
        gnupg && \
    rm -rf /var/lib/apt/lists/*

# Stage 1 copy: just enough for install-versions.yml to run. Keeping this
# layer separate from the full role COPY below means changes to bats
# tests, task files, etc. don't invalidate the slow apt + composer-phar
# install step.
COPY tests/matrix/install-versions.yml /tmp/matrix-setup/install-versions.yml
RUN ansible-playbook /tmp/matrix-setup/install-versions.yml \
        -i localhost, -c local && \
    rm -rf /tmp/matrix-setup

# Stage 2 copy: test fixtures to /opt/test-fixtures. The bats tests
# hardcode this path (matching tests/Dockerfile's convention for the
# single-version test harness) — composer-postinstall/composer.json,
# composer-local-dep/, npm-postinstall-pkg/, etc. all need to be at
# /opt/test-fixtures/ for the per-ecosystem bats files to function.
# Without this copy the FIXTURE CONTROL tests find no composer.json,
# composer install runs against empty input, post-install-cmd never
# fires, and "ATTACK blocked" / "LAYERED DEFENSE" tests pass by
# tautology — exactly the hollow-control problem 0bd53af fixed for
# the native bats run, re-introduced when docker mode forgot the
# fixture copy.
COPY tests/fixtures /opt/test-fixtures

# Stage 3 copy: the whole role. Invalidates on most commits but the
# previous layer's installs are preserved by Docker's build cache.
COPY . /workspace
WORKDIR /workspace

# Default command: run the matrix, then copy results out to /output
# (mounted by run-docker.sh). ECOSYSTEM env var controls which ecosystem's
# cells to run; defaults to composer.
CMD ["bash", "-c", "tests/matrix/run.sh ${ECOSYSTEM:-composer}; cp tests/matrix/results.json /output/results.json 2>/dev/null || echo 'no results.json produced'"]
