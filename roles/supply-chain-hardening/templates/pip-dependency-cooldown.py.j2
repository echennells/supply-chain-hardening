# Adapted for ansible-supply-chain-security
# Updates pip's uploaded-prior-to date to enforce a rolling release age gate.
import datetime, sys, os, re

def main():
    pip_conf = os.path.abspath(os.path.expanduser(sys.argv[1]))
    days = int(sys.argv[2])
    with open(pip_conf) as f:
        data = f.read()
    pattern = re.compile(
        r"^uploaded-prior-to\s*=\s*2[0-9]{3}-[0-9]{2}-[0-9]{2}$", re.MULTILINE
    )
    if not pattern.search(data):
        return 1
    new_date = (datetime.date.today() - datetime.timedelta(days=days)).strftime("%Y-%m-%d")
    data = pattern.sub(f"uploaded-prior-to = {new_date}", data)
    with open(pip_conf, "w") as f:
        f.write(data)

if __name__ == "__main__":
    sys.exit(main() or 0)
