# Managed by ansible-supply-chain-security
# Restrict which registries podman can pull from.

unqualified-search-registries = [{{ podman_allowed_registries | map('regex_replace', '/.*', '') | unique | map('to_json') | join(', ') }}]

{% for registry in podman_allowed_registries | map('regex_replace', '/.*', '') | unique %}
[[registry]]
prefix = "{{ registry }}"
location = "{{ registry }}"

{% endfor %}
# Short-name mode: enforcing means unqualified images (e.g. "nginx")
# must match an entry in unqualified-search-registries.
short-name-mode = "enforcing"
